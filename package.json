{
  "name": "tackbox",
  "version": "0.1.0",
  "description": "ESLint plugin + browser report helper: every failure must report, propagate, or explain itself.",
  "license": "MIT",
  "main": "./js/eslint-plugin.js",
  "exports": {
    ".": "./js/eslint-plugin.js",
    "./report": "./js/report.js"
  },
  "bin": {
    "tackbox-eslint": "./bin/tackbox-eslint.js",
    "tackbox-mdlint": "./bin/tackbox-mdlint.js"
  },
  "files": [
    "js/eslint-plugin.js",
    "js/report.js",
    "js/rules/",
    "js/markdownlint-rules/",
    "js/README.md",
    "bin/",
    "eslint.config.preset.js"
  ],
  "scripts": {
    "test": "node --test js/tests/*.test.js"
  },
  "peerDependencies": {
    "eslint": ">=8"
  },
  "dependencies": {
    "@sentry/browser": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "markdownlint": "0.40.0",
    "svelte": "^5.0.0",
    "svelte-eslint-parser": "^1.6.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nikitatsym/tackbox.git"
  },
  "engines": {
    "node": ">=20"
  }
}
